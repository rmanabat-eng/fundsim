// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Stage {
  PRE_SEED
  SEED
  SERIES_A
  SERIES_B
  SERIES_C
}

// Single-row table: the fund's knobs. Row id is always 1.
model FundSettings {
  id           Int   @id @default(1)
  fundSize     Float @default(10000000)
  maxCompanies Int   @default(15)
}

// A named snapshot of the whole portfolio + settings, for comparing
// strategies. `data` is a JSON blob — scenarios are read-mostly.
model Scenario {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  data      String
}

model Company {
  id        String    @id @default(cuid())
  name      String
  sector    String
  createdAt DateTime  @default(now())
  exitValue Float? // company valuation at exit; 0 means written off; null = still active
  exitDate  DateTime?
  quality   Float     @default(0) // hidden -1..1; tilts campaign-mode outcomes. 0 for free-play companies.
  dealId    String?   @unique // the pitch this company was funded from; lets a first check be undone before the year advances
  deal      Deal?     @relation(fields: [dealId], references: [id])
  rounds    Round[]
  decisions Decision[]
}

// ---- Campaign mode ----

// The running campaign. Single row (id 1); no row means no campaign started.
model Game {
  id        Int      @id @default(1)
  year      Int      @default(1)
  status    String   @default("active") // "active" | "ended"
  market    String   @default("normal") // this year's conditions: "bull" | "normal" | "bear"
  startedAt DateTime @default(now())
}

// A pitch dealt to the player for one campaign year. `quality` is the hidden
// score its signals (noisily) encode — never shown, only its consequences.
model Deal {
  id        String @id @default(cuid())
  year      Int
  name      String
  sector    String
  stage     Stage
  raised    Float
  postMoney Float
  signals   String // JSON array of signal texts shown on the pitch card
  quality   Float
  status    String @default("open") // "open" | "invested" | "passed" | "expired"
  company   Company? // set when invested; cleared if the investment is undone
}

// A decision forced on the player: fund a pro-rata, take an acquisition
// offer, bridge a struggling company, or advise a founder (pick between
// term sheets, bless a pivot). Expires against the player if unresolved
// when the year advances.
model Decision {
  id        String  @id @default(cuid())
  year      Int
  type      String // "pro_rata" | "acquisition" | "bridge" | "term_sheet" | "pivot"
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payload   String // JSON, shape depends on type
  status    String  @default("pending") // "pending" | "resolved" | "declined" | "expired" | "moot"
}

model Round {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stage     Stage
  date      DateTime
  raised    Float // total new money in the round
  postMoney Float // company valuation after the round closes
  yourCheck Float // your fund's participation; 0 if you sat the round out
}
